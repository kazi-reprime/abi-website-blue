/* ============================================================
   RESPONSIVE — mobile (base) · tablet · desktop
   Keeps the exact reference look; reflows card groups to fill
   wider screens. Text/heading spans full row; cards flow to columns.
   ============================================================ */
/* Full-bleed: bars & sections span the FULL viewport width; content is
   centered inside a readable band via auto side-gutters. No side cutouts. */
.fullbleed,
.ann,.hdr,.phones,.hero,.form-sec,.cd,.fcta,footer,.ticker,.haircut-bar,.sec{--band:430px}
@media(min-width:680px){
  body{max-width:none;width:100%;padding-bottom:72px}
  .ann,.hdr,.phones,.hero,.form-sec,.cd,.fcta,footer,.ticker,.haircut-bar,.sec{--band:720px;
    padding-left:max(24px,calc((100% - var(--band))/2));
    padding-right:max(24px,calc((100% - var(--band))/2));}
  .sec{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;align-items:start;padding-top:36px;padding-bottom:36px}
  .sec > *{grid-column:1/-1}
  .sec > .step,.sec > .plan,.sec > .earn,.sec > .info,.sec > .mod,.sec > .lkcard,.sec > .rcard,.sec > .faq{grid-column:auto;margin-bottom:0}
  .sticky{max-width:none;left:0;transform:none}
}
@media(min-width:1000px){
  body{padding-bottom:0}
  .ann,.hdr,.phones,.hero,.form-sec,.cd,.fcta,footer,.ticker,.haircut-bar,.sec{--band:1200px;
    padding-left:max(40px,calc((100% - var(--band))/2));
    padding-right:max(40px,calc((100% - var(--band))/2));}
  .sec{grid-template-columns:repeat(3,1fr);padding-top:60px;padding-bottom:60px}
  .sec > .faq{grid-column:span 1}
  .igrid{grid-template-columns:repeat(3,1fr)}
  .get-grid{grid-template-columns:repeat(3,1fr)}
  .ggrid{grid-template-columns:repeat(4,1fr)}
  .gimg{height:170px}
  .stit{font-size:27px !important}
  .hero-h{font-size:34px}
  .page-hero h1{font-size:38px}
  .page-hero{padding-top:64px;padding-bottom:56px}
  .form-sec .form-box{max-width:660px;margin:0 auto}
  .hero{padding-top:34px}
  .sticky{display:none}
  .ticker{font-size:13px}
}
@media(min-width:1500px){
  .ann,.hdr,.phones,.hero,.form-sec,.cd,.fcta,footer,.ticker,.haircut-bar,.sec{--band:1320px}
}

