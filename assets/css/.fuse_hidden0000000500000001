
/* ===== ADDITIONS (menu, form states) — do not alter base design ===== */
.navmenu{position:fixed;top:0;right:0;bottom:0;width:min(82%,330px);background:#0D2B4E;z-index:10000;transform:translateX(110%);transition:transform .3s ease;overflow-y:auto;padding:18px;box-shadow:-8px 0 30px rgba(0,0,0,.4)}
body.menu-open .navmenu{transform:none}
.navmenu-bd{position:fixed;inset:0;background:rgba(7,25,46,.55);z-index:9998;opacity:0;visibility:hidden;transition:.3s}
body.menu-open .navmenu-bd{opacity:1;visibility:visible}
.navmenu-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.navmenu-top span{color:#fff;font-weight:900;font-size:15px}
.navmenu-x{background:none;border:none;color:#fff;font-size:26px;line-height:1;cursor:pointer}
.navmenu a{display:block;color:#B5D4F4;padding:11px 6px;border-bottom:1px solid rgba(255,255,255,.1);font-weight:700;font-size:14px;text-decoration:none}
.navmenu a:hover{color:#fff}
.form-done{display:none;text-align:center;padding:22px 6px}
.form-done .tk{width:56px;height:56px;border-radius:50%;background:#639922;color:#fff;display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 12px}
.form-done h4{color:#fff;font-size:16px;margin-bottom:6px}
.form-done p{color:#B5D4F4;font-size:12px;line-height:1.6}
.fi.err,.fs.err,.ft.err{border-color:#E24B4A!important}

/* ===== Interior-page helpers (same palette/typography as reference) ===== */
.page-hero{background:#0D2B4E;padding:22px 14px 20px}
.page-hero .crumb{font-size:11px;color:#B5D4F4;margin-bottom:8px}
.page-hero .crumb a{color:#B5D4F4;text-decoration:none}
.page-hero .crumb a:hover{color:#fff}
.page-hero h1{font-size:24px;font-weight:900;color:#fff;line-height:1.15;margin-bottom:8px;letter-spacing:-.3px}
.page-hero p{font-size:13px;color:#B5D4F4;line-height:1.6}
.page-hero .pbtns{display:flex;gap:8px;margin-top:14px;flex-wrap:wrap}
.sd .stit,.stit-w{color:#fff}
.sd .sdesc{color:#B5D4F4}
.kgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:14px 0}
.kbox{background:#F0F6FF;border:1.5px solid #D6E4F7;border-radius:8px;padding:12px 6px;text-align:center}
.kbox .kn{font-size:18px;font-weight:900;color:#1252A3;line-height:1}
.kbox .kl{font-size:9px;color:#5F5E5A;margin-top:4px;font-weight:600}
.info{background:#fff;border:1.5px solid #D6E4F7;border-radius:12px;padding:14px;margin-bottom:10px}
.info h3{font-size:14px;font-weight:900;color:#0D2B4E;margin-bottom:8px}
.info p{font-size:12px;color:#5F5E5A;line-height:1.7}
.mod{background:#fff;border:1.5px solid #D6E4F7;border-radius:12px;padding:14px;margin-bottom:10px}
.mod-n{font-size:11px;font-weight:800;color:#1252A3;letter-spacing:.06em;margin-bottom:4px}
.mod h3{font-size:14px;font-weight:900;color:#0D2B4E;margin-bottom:8px}
.mod .skill{font-size:12px}
.lkcard{display:block;background:#fff;border:1.5px solid #D6E4F7;border-radius:12px;padding:14px;margin-bottom:10px;text-decoration:none}
.lkcard:hover{border-color:#1252A3}
.lkcard .lkt{font-size:14px;font-weight:900;color:#0D2B4E;margin-bottom:3px}
.lkcard .lkd{font-size:12px;color:#5F5E5A;line-height:1.5}
@media(min-width:760px){
  /* tasteful desktop: keep the exact mobile card centered, just add a backdrop */
  body{box-shadow:0 0 60px rgba(13,43,78,.18)}
}

/* ============================================================
   MENU GROUPS + THEME TOGGLE  (added)
   ============================================================ */
.navmenu .ng{font-size:10px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:#7FA8D8;margin:14px 6px 2px;padding-top:8px;border-top:1px solid rgba(255,255,255,.12)}
.navmenu .nm-home{font-weight:900;color:#fff}
.theme-btn{width:34px;height:34px;border-radius:8px;border:1px solid rgba(255,255,255,.25);background:rgba(255,255,255,.10);color:#fff;font-size:15px;line-height:1;display:flex;align-items:center;justify-content:center;cursor:pointer;padding:0}
.theme-btn:hover{background:rgba(255,255,255,.20)}

